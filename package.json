{
  "name": "llm-wiki",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "corepack pnpm -r test",
    "coverage": "vitest run --config vitest.coverage.config.ts --coverage",
    "test:release-version": "node --test scripts/set-release-version.test.mjs",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "prettier": "^3.8.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^3.1.0"
  }
}
