#!/usr/bin/env bash
# Pre-commit hook — llm-wiki
#
# Policy decisions (locked — do not weaken without project-wide discussion):
#   - batch:   all checks run, every failure is reported, hook returns 1 if ANY failed
#   - fail:    prettier violations BLOCK the commit; no auto-fix, no auto `git add`
#   - related: vitest runs `related --run` against staged source files (fast, narrow)
#   - strict:  no `SKIP=1` / `BD_SKIP_HOOK` / env-based escape hatch built into this script
#
# Note on `git commit --no-verify`: that is a git-level bypass and cannot be blocked
# from inside the hook itself. Treat its use as a signal to open a PR discussion,
# not as a sanctioned workflow.

set -u

RED=$(printf '\033[31m')
GRN=$(printf '\033[32m')
YLW=$(printf '\033[33m')
DIM=$(printf '\033[2m')
RST=$(printf '\033[0m')

say() { printf '%s▶%s %s\n' "$DIM" "$RST" "$1"; }
ok()  { printf '%s✓%s %s\n' "$GRN" "$RST" "$1"; }
bad() { printf '%s✗%s %s\n' "$RED" "$RST" "$1"; }
warn(){ printf '%s!%s %s\n' "$YLW" "$RST" "$1"; }

# Collect staged files (Added / Copied / Modified). Newline-separated.
mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACM)

if [ ${#staged[@]} -eq 0 ]; then
  ok "nothing staged — hook skipped"
  exit 0
fi

staged_ts=()
staged_prettier=()
for f in "${staged[@]}"; do
  case "$f" in
    pnpm-lock.yaml) continue ;;
    *.md)           continue ;;  # .md is in .prettierignore, skip entirely
  esac
  case "$f" in
    *.ts|*.tsx|*.mts|*.cts) staged_ts+=("$f"); staged_prettier+=("$f") ;;
    *.js|*.mjs|*.cjs)       staged_ts+=("$f"); staged_prettier+=("$f") ;;
    *.json|*.jsonc|*.yaml|*.yml|*.css|*.html) staged_prettier+=("$f") ;;
  esac
done

# Stash unstaged working-tree changes so checks see exactly what will be committed.
# Use a labeled stash + trap to guarantee restore even on crash.
stash_created=0
if ! git diff --quiet; then
  if git stash push --keep-index --include-untracked -q -m "pre-commit-$$"; then
    stash_created=1
  else
    warn "could not stash unstaged changes — checks may see working-tree state"
  fi
fi
restore_stash() {
  if [ "$stash_created" = "1" ]; then
    git stash pop -q >/dev/null 2>&1 || warn "stash pop failed — run 'git stash list'"
  fi
}
trap restore_stash EXIT

status=0

# ─── 1. ESLint on staged TS/JS ────────────────────────────────────────────────
if [ ${#staged_ts[@]} -gt 0 ]; then
  say "eslint (${#staged_ts[@]} file(s))"
  if pnpm exec eslint "${staged_ts[@]}"; then
    ok "eslint clean"
  else
    bad "eslint failed"
    status=1
  fi
fi

# ─── 2. Prettier --check on staged formattable files ─────────────────────────
if [ ${#staged_prettier[@]} -gt 0 ]; then
  say "prettier --check (${#staged_prettier[@]} file(s))"
  if pnpm exec prettier --check "${staged_prettier[@]}"; then
    ok "prettier clean"
  else
    bad "prettier failed — run \`pnpm format\` and re-stage"
    status=1
  fi
fi

# ─── 3. Full incremental typecheck ────────────────────────────────────────────
say "tsc -b (full incremental)"
if pnpm -w typecheck >/dev/null; then
  ok "typecheck clean"
else
  bad "typecheck failed"
  pnpm -w typecheck || true
  status=1
fi

# ─── 4. Vitest workspace run ─────────────────────────────────────────────────
# Two important details about this step:
#
# 1. Env hygiene: git sets GIT_DIR / GIT_INDEX_FILE / GIT_WORK_TREE in the
#    hook's environment. Those leak through pnpm → vitest → simple-git and
#    poison tests that create their own temporary git repos (all the
#    worktree / ingest-e2e tests). We unset them with `env -u` so each
#    simple-git subprocess discovers its temp repo cleanly.
#
# 2. Scope: user decision was `vitest related --run <staged>`, but the
#    `related` command bypasses the per-project isolation defined in
#    vitest.workspace.ts. Full workspace run (`pnpm -w test`) uses the
#    projects config and is reliable. At ~7s for the current 224-test suite
#    the overhead is acceptable for a pre-commit gate; if the suite grows
#    past ~30s, switch to `vitest --project <name>` filtered by staged-file
#    location instead of the broken `related` command.
if [ ${#staged_ts[@]} -gt 0 ]; then
  say "vitest (full workspace run)"
  if env -u GIT_DIR -u GIT_INDEX_FILE -u GIT_WORK_TREE -u GIT_PREFIX \
       pnpm -w test >/dev/null 2>&1; then
    ok "tests clean"
  else
    bad "tests failed"
    env -u GIT_DIR -u GIT_INDEX_FILE -u GIT_WORK_TREE -u GIT_PREFIX \
      pnpm -w test || true
    status=1
  fi
fi

echo
if [ $status -ne 0 ]; then
  bad "pre-commit: commit blocked (batch mode — see all failures above)"
  exit 1
fi

ok "pre-commit: all checks passed"
exit 0
