{
  "name": "@ivkond-llm-wiki/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivkond/llm-memory.git",
    "directory": "packages/mcp-server"
  },
  "main": "./dist/index.js",
  "types": "./dist/main.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "llm-wiki-mcp": "dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && node -e \"require('node:fs').writeFileSync('dist/main.d.ts','export {};\\n')\"",
    "prepack": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "@ai-sdk/openai": "^1.3.24",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^5.0.172",
    "globby": "^14.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "minisearch": "^7.2.0",
    "node-7z": "^3.0.0",
    "re2": "^1.22.3",
    "ruvector": "^0.2.22",
    "simple-git": "^3.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@ivkond-llm-wiki/common": "workspace:*",
    "@ivkond-llm-wiki/infra": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
