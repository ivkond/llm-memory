{
  "name": "@ivkond-llm-wiki/cli",
  "version": "0.1.0",
  "description": "CLI for LLM Wiki operations",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivkond/llm-memory.git",
    "directory": "packages/cli"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "llm-wiki": "dist/index.js",
    "multica": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./commands": "./dist/commands/index.js"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc -b tsconfig.json --emitDeclarationOnly --force",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "lint": "tsc -b"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "@ai-sdk/openai": "^1.3.24",
    "ai": "^5.0.172",
    "commander": "^12.1.0",
    "globby": "^14.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "minisearch": "^7.2.0",
    "node-7z": "^3.0.0",
    "re2": "^1.22.3",
    "ruvector": "^0.2.22",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@ivkond-llm-wiki/common": "workspace:*",
    "@ivkond-llm-wiki/infra": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
